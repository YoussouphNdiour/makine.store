generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String
  price       Float
  priceXOF    Int
  priceXOF2   Int?
  category    String
  badge       String?
  imageUrl    String?
  stockQty    Int?         // null = illimité, number = quantité finie
  isBundle    Boolean      @default(false)
  inStock     Boolean      @default(true)
  wholesale   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  orderItems  OrderItem[]
  bundleItems BundleItem[] @relation("BundleParent")
  componentOf BundleItem[] @relation("BundleComponent")
}

model BundleItem {
  id          String  @id @default(cuid())
  bundleId    String
  componentId String
  qty         Int     @default(1)
  bundle      Product @relation("BundleParent", fields: [bundleId], references: [id], onDelete: Cascade)
  component   Product @relation("BundleComponent", fields: [componentId], references: [id])

  @@unique([bundleId, componentId])
  @@index([bundleId])
}

model Order {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  customerName  String
  customerPhone String
  customerEmail String?
  address       String?
  country       String
  currency      String
  totalAmount   Float
  paymentMethod String
  paymentStatus String      @default("pending")
  paymentRef    String?
  wavePayoutId  String?
  whatsappSent  Boolean     @default(false)
  status        String      @default("new")
  isWholesale   Boolean     @default(false)
  notes         String?
  items         OrderItem[]

  @@index([paymentStatus])
  @@index([status])
  @@index([paymentMethod])
  @@index([createdAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model WhatsappSession {
  id             String   @id @default(cuid())
  phone          String   @unique
  state          String   @default("greeting")
  cart           Json     @default("[]")
  customerName   String?
  customerPhone  String?
  country        String   @default("SN")
  lastMsg        DateTime @default(now())
  createdAt      DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  country   String?
  createdAt DateTime @default(now())
}
